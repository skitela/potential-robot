{
  "schema_name": "codex_gpt54_orchestrator_mailbox",
  "version": "1.0.0",
  "description": "Schemat wymiany dla Orchestratora Codex <-> GPT-5.4 Pro opartego o pliki i kolejke lokalna.",
  "request_states": [
    "NEW",
    "PENDING",
    "PICKED",
    "PROCESSING",
    "ANSWER_WRITTEN",
    "ACKED",
    "DONE",
    "FAILED",
    "HOLD"
  ],
  "folders": {
    "requests_pending": "requests/pending",
    "requests_in_progress": "requests/in_progress",
    "requests_done": "requests/done",
    "requests_failed": "requests/failed",
    "responses_ready": "responses/ready",
    "responses_consumed": "responses/consumed",
    "responses_extracted": "responses/extracted",
    "coordination_claims_active": "coordination/claims/active",
    "coordination_claims_released": "coordination/claims/released",
    "coordination_tasks_pending": "coordination/tasks/pending",
    "coordination_tasks_active": "coordination/tasks/active",
    "coordination_tasks_blocked": "coordination/tasks/blocked",
    "coordination_tasks_done": "coordination/tasks/done",
    "coordination_activity": "coordination/activity",
    "notes_inbox": "notes/inbox",
    "notes_archive": "notes/archive",
    "ack_executor": "ack/executor",
    "ack_reviewer": "ack/reviewer",
    "status": "status",
    "logs": "logs"
  },
  "request_sidecar_fields": {
    "required": [
      "request_id",
      "title",
      "source_path",
      "source_file_name",
      "source_sha256",
      "queued_at_local"
    ],
    "optional": [
      "topic",
      "phase",
      "source_role",
      "target_role",
      "repo_root",
      "report_file",
      "attachments",
      "requires_ack_from",
      "extra_instructions_present",
      "status"
    ]
  },
  "response_manifest_fields": {
    "required": [
      "request_id",
      "request_path",
      "response_path",
      "extracted_root",
      "extracted_files",
      "status"
    ],
    "optional": [
      "request_meta",
      "html_snapshot_saved",
      "html_path",
      "published_notes"
    ]
  },
  "note_fields": {
    "required": [
      "note_id",
      "title",
      "author",
      "source",
      "note_path",
      "written_at_local"
    ],
    "optional": [
      "request_id",
      "request_title",
      "relative_path",
      "tags"
    ]
  },
  "ack_fields": {
    "required": [
      "request_id",
      "actor",
      "ack_type",
      "written_at_local"
    ],
    "optional": [
      "notes",
      "source_response_path"
    ]
  },
  "claim_fields": {
    "required": [
      "claim_id",
      "actor",
      "work_title",
      "created_at_local",
      "expires_at_local",
      "state"
    ],
    "optional": [
      "actor_session",
      "report_path",
      "scope_paths",
      "notes",
      "conflicts_with",
      "released_at_local",
      "release_notes",
      "outcome"
    ]
  },
  "task_fields": {
    "required": [
      "task_id",
      "title",
      "assigned_to",
      "source_actor",
      "created_at_local",
      "status"
    ],
    "optional": [
      "request_id",
      "parent_claim_id",
      "report_path",
      "scope_paths",
      "instructions",
      "priority",
      "started_at_local",
      "completed_at_local",
      "blocked_at_local",
      "updated_at_local",
      "last_activity_at_local",
      "last_activity_title",
      "last_activity_notes",
      "outcome"
    ]
  },
  "activity_fields": {
    "required": [
      "activity_id",
      "actor",
      "title",
      "written_at_local"
    ],
    "optional": [
      "task_id",
      "claim_id",
      "report_path",
      "scope_paths",
      "notes"
    ]
  }
}
