DIAG/

# Evidence and archives (keep curated report only)
EVIDENCE/*
!EVIDENCE/oanda_limits_audit_report.md

# Large reference docs (keep curated text elsewhere)
DOCS/OANDA/
DOCS/OANDA/_extract/
DOCS/OANDA/*.pdf
README/*.pdf
README/*.docx

# Archives/builds
ARCHIVE/
dist/
*.log
*.zip

# Sensitive or volatile dirs
HOTFIX/
LOCK/
META/
OANDAKEY/

# Defensive ignore for accidental secret drops (DPAPI artifacts)
LLM_SECRETS_DPAPI/
SECRETS/
*.dpapi
*api_key*.dpapi

# Checksums or generated lists
CHECKSUMS_BINARIES_SHA256.txt
