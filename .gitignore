# Defensive ignore for accidental secret drops (DPAPI artifacts)
LLM_SECRETS_DPAPI/
SECRETS/
*.dpapi
*api_key*.dpapi

# Checksums or generated lists
CHECKSUMS_BINARIES_SHA256.txt
