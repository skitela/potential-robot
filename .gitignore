__pycache__/
.pycache/
*.pyc
*.pyo
.mypy_cache/
.pytest_cache/
.ruff_cache/
.coverage
.tmp/
.tmp_py/
TMP_AUDIT_IO/

# Editor/IDE
.vs/
.vscode/

# Runtime outputs
LOGS/
RUN/
DATA/
DB/
DB_BACKUPS/
