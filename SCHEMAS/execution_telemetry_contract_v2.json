{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "oanda://schemas/execution_telemetry_contract_v2",
  "title": "Execution Telemetry Contract v2",
  "type": "object",
  "required": [
    "event_type",
    "timestamp_semantics",
    "ts_utc",
    "symbol_raw",
    "symbol_canonical",
    "deviation_requested_points",
    "deviation_unit",
    "sample_size_n",
    "low_stat_power"
  ],
  "properties": {
    "event_type": { "type": "string", "minLength": 1 },
    "correlation_id": { "type": ["string", "null"] },
    "request_id": { "type": ["string", "null"] },
    "command_id": { "type": ["string", "null"] },
    "message_id": { "type": ["string", "null"] },
    "symbol_raw": { "type": "string", "minLength": 1 },
    "symbol_canonical": { "type": "string", "minLength": 1 },
    "group": { "type": ["string", "null"] },
    "request_price": { "type": ["number", "null"] },
    "fill_price": { "type": ["number", "null"] },
    "spread_at_decision": { "type": ["number", "null"] },
    "spread_unit": { "type": "string", "enum": ["price", "points", "ticks", "pips", "AMBIGUOUS_UNIT", "UNKNOWN"] },
    "spread_provenance": { "type": "string" },
    "slippage_abs_price": { "type": ["number", "null"] },
    "slippage_points": { "type": ["number", "null"] },
    "slippage_ticks": { "type": ["number", "null"] },
    "deviation_requested_points": { "type": "integer", "minimum": 0 },
    "deviation_effective_points": { "type": ["integer", "null"], "minimum": 0 },
    "deviation_expected_points": { "type": ["integer", "null"], "minimum": 0 },
    "deviation_unit": { "type": "string", "const": "points" },
    "retcode": { "type": ["integer", "null"] },
    "retcode_name": { "type": ["string", "null"] },
    "estimated_entry_cost_components": { "type": ["object", "null"] },
    "estimated_round_trip_cost": { "type": ["object", "null"] },
    "realized_cost_components": { "type": ["object", "null"] },
    "cost_estimation_quality": { "type": "string", "enum": ["DIRECT", "PARTIAL", "HEURISTIC", "UNKNOWN"] },
    "cost_feasibility_shadow": { "type": ["boolean", "null"] },
    "cost_feasibility_mode": { "type": ["string", "null"] },
    "target_move_price": { "type": ["number", "null"] },
    "source_provenance": { "type": "string" },
    "timezone_basis": { "type": "string", "enum": ["UTC", "MT5_SERVER_DERIVED", "WARSAW_DERIVED", "UNKNOWN"] },
    "timestamp_semantics": { "type": "string", "enum": ["UTC", "MT5_SERVER_DERIVED", "WARSAW_DERIVED", "UNKNOWN"] },
    "ts_utc": { "type": "string", "minLength": 1 },
    "exact_window": { "type": ["string", "null"] },
    "source_list": {
      "type": "array",
      "items": { "type": "string" }
    },
    "symbol_filter": { "type": ["string", "null"] },
    "method": { "type": "string" },
    "sample_size_n": { "type": "integer", "minimum": 1 },
    "low_stat_power": { "type": "boolean" }
  },
  "additionalProperties": true
}
