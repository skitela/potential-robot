      "net profit after full costs",
      "capital protection",
      "cleaner and faster runtime",
      "research-to-runtime parity"
    ]
  },
  "core_dirty_gate_policy": {
    "core_system_changes_block_release": true,
    "auxiliary_bridge_changes_block_release": false,
    "generated_artifacts_block_release": false
