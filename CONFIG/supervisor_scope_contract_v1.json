{
  "schema_version": "1.0",
  "contract_kind": "supervisor_scope_boundary",
  "purpose": "Separate core Macro/Micro Bot supervision from auxiliary bridge, orchestrator and brigade tooling.",
  "system_identity": {
    "name": "macro_i_mikro_bot_core",
