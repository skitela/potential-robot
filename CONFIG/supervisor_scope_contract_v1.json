    },
    {
      "id": "desktop_tuning_exchange",
      "label": "Pulpit strojenie agenta",
      "needle": "Desktop\\strojenie agenta"
    },
    {
      "id": "brigades_docs",
      "label": "Dokumentacja brygad",
      "needle": "BRYGADY\\"
    },
    {
      "id": "brigade_index",
      "label": "Indeks brygad",
      "needle": "00_BRYGADY_TUTAJ.md"
    },
    {
