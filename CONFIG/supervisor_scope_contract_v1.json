    "RUN/RUN_AUTONOMOUS_90P_SUPERVISOR.ps1",
    "RUN/BUILD_FULL_STACK_AUDIT.ps1",
    "RUN/MAINTAIN_LEARNING_WELLBEING.ps1",
    "RUN/BUILD_LEARNING_HEALTH_REGISTRY.ps1",
    "RUN/CLEAN_LEARNING_SUPERVISOR_HOT_PATH.ps1",
    "RUN/BUILD_AUDIT_SUPERVISOR_DISCOVERY_REPORT.ps1",
    "RUN/BUILD_REPO_HYGIENE_REPORT.ps1"
  ],
  "forbidden_auxiliary_refs_in_supervisors": [
    {
      "id": "orchestrator_mailbox",
      "label": "Mailbox mostu brygad",
