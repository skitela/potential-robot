{
  "schema_version": "1.0",
  "schema_id": "teacher_package_schema_v1",
  "intent": "Compatibility-first teacher package for a shared runtime",
  "allowed_teacher_package_modes": [
    "GLOBAL_ONLY",
    "GLOBAL_PLUS_PERSONAL",
    "PERSONAL_PRIMARY"
  ],
  "compatibility_rules": [
    "teacher_package_mode must stay separate from paper_live_bucket",
    "teacher_package_snapshot is supplemental and must not replace supervisor_snapshot or learning_supervisor_snapshot",
    "teacher_mode in the learning universe contract remains cohort-level and is not replaced by runtime package mode",
    "phase 1 must not assume ONNX teacher routing changes"
  ],
  "contract_fields": [
    {"name": "enabled", "type": "bool", "required": true},
    {"name": "student_gate_enabled", "type": "bool", "required": true},
    {"name": "teacher_required", "type": "bool", "required": true},
    {"name": "outcome_ready", "type": "bool", "required": true},
    {"name": "local_model_available", "type": "bool", "required": true},
    {"name": "global_model_available", "type": "bool", "required": true},
    {"name": "paper_live_enabled", "type": "bool", "required": true},
    {"name": "local_training_mode", "type": "string", "required": true},
    {"name": "runtime_scope", "type": "string", "required": true},
    {"name": "paper_live_bucket", "type": "string", "required": true},
    {"name": "teacher_package_mode", "type": "string", "required": true},
    {"name": "teacher_scope", "type": "string", "required": true},
    {"name": "teacher_id", "type": "string", "required": true},
    {"name": "symbol", "type": "string", "required": true},
    {"name": "symbol_family", "type": "string", "required": true},
    {"name": "personal_allowed", "type": "bool", "required": true},
    {"name": "teacher_policy_id", "type": "string", "required": true},
    {"name": "universe_version", "type": "string", "required": true},
    {"name": "plan_hash", "type": "string", "required": true},
    {"name": "min_gate_probability", "type": "float", "required": true},
    {"name": "min_decision_score_pln", "type": "float", "required": true},
    {"name": "max_spread_points", "type": "float", "required": true},
    {"name": "max_server_ping_ms", "type": "float", "required": true},
    {"name": "max_server_latency_us_avg", "type": "float", "required": true}
  ],
  "manifest_fields": [
    {"name": "teacher_id", "type": "string", "required": true},
    {"name": "scope", "type": "string", "required": true},
    {"name": "symbol", "type": "string", "required": true},
    {"name": "symbol_family", "type": "string", "required": true},
    {"name": "teacher_package_mode", "type": "string", "required": true},
    {"name": "deployment_bucket", "type": "string", "required": true},
    {"name": "local_training_mode", "type": "string", "required": true},
    {"name": "feature_count", "type": "int", "required": true},
    {"name": "features", "type": "list[str]", "required": true},
    {"name": "required_features", "type": "list[str]", "required": true},
    {"name": "inherits_global", "type": "bool", "required": true},
    {"name": "thresholds", "type": "object", "required": true},
    {"name": "promotion_gate", "type": "object", "required": true},
    {"name": "policy_ref", "type": "object", "required": true},
    {"name": "artifacts", "type": "object", "required": true}
  ],
  "promotion_snapshot_fields": [
    {"name": "symbol", "type": "string", "required": true},
    {"name": "teacher_package_mode", "type": "string", "required": true},
    {"name": "teacher_score", "type": "float", "required": true},
    {"name": "student_score", "type": "float", "required": true},
    {"name": "lesson_ready", "type": "bool", "required": true},
    {"name": "knowledge_ready", "type": "bool", "required": true},
    {"name": "gate_visible", "type": "bool", "required": true},
    {"name": "outcome_ready", "type": "bool", "required": true},
    {"name": "full_lessons_window", "type": "int", "required": true},
    {"name": "gate_visible_events_window", "type": "int", "required": true},
    {"name": "feature_coverage_ratio", "type": "float", "required": true},
    {"name": "days_observed", "type": "int", "required": true},
    {"name": "unclassified_count", "type": "int", "required": true},
    {"name": "sticky_diagnostic", "type": "bool", "required": true},
    {"name": "relative_quality_vs_global", "type": "float", "required": true},
    {"name": "quality_drop_vs_baseline", "type": "float", "required": true},
    {"name": "source_refs", "type": "object", "required": true}
  ],
  "history_fields": [
    {"name": "current_mode", "type": "string", "required": false},
    {"name": "recent_verdicts", "type": "list[object|string]", "required": false},
    {"name": "last_promotion_at_utc", "type": "datetime|string|int", "required": false},
    {"name": "last_rollback_at_utc", "type": "datetime|string|int", "required": false}
  ]
}
